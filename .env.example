# MLB Predictive System — Environment Configuration
# Copy to .env and fill in your values.

# Database
DATABASE_URL=postgresql://mlb_user:password@localhost:5432/mlb_predictive

# API Keys
WEATHER_API_KEY=your_weather_gov_api_key
ODDS_API_KEY=your_the_odds_api_key

# JWT
JWT_SECRET=change-this-to-a-random-secret-in-production

# Bankroll
BANKROLL_INITIAL=10000

# Data directories (defaults: data/, models/, logs/)
MLB_DATA_DIR=data
MLB_MODELS_DIR=models
MLB_LOGS_DIR=logs

# Logging
LOG_LEVEL=INFO

# CORS (comma-separated origins for production)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
